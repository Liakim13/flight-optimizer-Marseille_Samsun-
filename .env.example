# --- SerpApi (Google Flights) ---
SERPAPI_API_KEY=votre_cle_serpapi

# --- Itinéraire ---
DEPARTURE_AIRPORT=MRS
ARRIVAL_AIRPORT=SZF
HUB_AIRPORTS=IST,SAW
TARGET_AIRLINES=TK,PC

# --- Paramètres de scan (optimisation SerpApi) ---
SCAN_MONTHS=3
SCAN_STEP_DAYS=7
DATE_OFFSET_DAYS=2
STAY_PROFILES_DAYS=14,21,28
MIN_LAYOVER_MINUTES=45
MAX_LAYOVER_MINUTES=360
API_DELAY_SECONDS=1.5
MAX_OPTIONS_PER_SEARCH=1
API_CACHE_HOURS=168
MAX_API_CALLS_PER_RUN=200

# --- Seuil d'alerte opportunité (baisse vs veille) ---
PRICE_DROP_THRESHOLD_PERCENT=5
PRICE_DROP_THRESHOLD_EUR=30

# --- Localisation des prix ---
CURRENCY=EUR
GL=fr
HL=fr

# --- SMTP (exemple Gmail : smtp.gmail.com / port 587 + mot de passe d'application) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
EMAIL_FROM=votre.email@gmail.com
EMAIL_TO=votre.email@gmail.com

# --- Base de données (cache GitHub Actions en cloud) ---
DATABASE_PATH=data/prices.db

# --- Planification ---
# En production : GitHub Actions (.github/workflows/main.yml, cron 20h Paris)
# En local    : python main.py ou python main.py --dry-run
